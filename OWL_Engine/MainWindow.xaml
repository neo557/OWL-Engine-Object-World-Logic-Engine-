<Window x:Class="OWL_Engine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Grid Engine'OWL Engine'"
        Width="900"
        Height="800"
         PreviewKeyDown="Window_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="250" />
        </Grid.ColumnDefinitions>

        <!-- 左：Hierarchy（階層構造） -->
        <TreeView x:Name="HierarchyTree"
                  AllowDrop="True"
              KeyboardNavigation.DirectionalNavigation="None"
              KeyboardNavigation.TabNavigation="None"
              Grid.Column="0"
              Background="White"
              Foreground="#222"
              SelectedItemChanged="HierarchyTree_SelectedItemChanged">
            <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsTabStop" Value="False"/>
                </Style>
            </TreeView.Resources>
        </TreeView>
        <!--中央:３Dモデル表示-->
        <Viewport3D Name="View3D"  Grid.Column="1" MouseDown="View3D_MouseDown" >
            <Viewport3D.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Create Cube" Click="CreateCube_Click"/>
                    <MenuItem Header="Create Rectangle" Click="CreateRectangle_Click"/>
                    <MenuItem Header="Create Triangle" Click="CreateTriangle_Click"/>
                </ContextMenu>
            </Viewport3D.ContextMenu>

            <Viewport3D.Camera>
                <PerspectiveCamera Position="20, 20, 20"
                           LookDirection="-20, -20, -20"
                           UpDirection="0, 1, 0"
                           FieldOfView="60" />
            </Viewport3D.Camera>


        </Viewport3D>


        <!-- 右：Inspector（詳細情報） -->
        <DockPanel Grid.Column="2" Background="#222">
            <TextBlock Text="Inspector" Foreground="White" FontSize="16" Margin="5"/>

            <StackPanel Margin="5">
                <TextBlock Text="Name" Foreground="White"/>
                <TextBox x:Name="InspectorName"/>

                <TextBlock Text="Parent" Foreground="White" Margin="0,10,0,0"/>
                <ComboBox x:Name="InspectorParent"/>
            </StackPanel>
        </DockPanel>

        <ComboBox x:Name="GridSize"
  SelectionChanged="GridSizeBox_SelectionChanged" Grid.Column="2" Margin="0,583,0,176" HorizontalAlignment="Center" Width="250" Height="25">
            <ComboBoxItem Content="1" />
            <ComboBoxItem Content="0.5" />
            <ComboBoxItem Content="0.25" />
            <ComboBoxItem Content="0.125" />
            <ComboBoxItem Content="0.0625" />
        </ComboBox>

    </Grid>

</Window>