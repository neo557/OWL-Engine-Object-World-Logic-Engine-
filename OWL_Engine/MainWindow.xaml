<Window x:Class="OWL_Engine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Grid Engine'OWL Engine'"
        Width="900"
        Height="800"
         PreviewKeyDown="Window_KeyDown">


    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="250" />
        </Grid.ColumnDefinitions>

        <!-- 左：Hierarchy（階層構造） -->
        <TreeView x:Name="HierarchyTree"
                  AllowDrop="True"
              KeyboardNavigation.DirectionalNavigation="None"
              KeyboardNavigation.TabNavigation="None"
              Grid.Column="0"
              Background="Gray"
              Foreground="#222"
              SelectedItemChanged="HierarchyTree_SelectedItemChanged" Margin="0,19,0,0">
            <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsTabStop" Value="False"/>
                </Style>
            </TreeView.Resources>
        </TreeView>


        <!--中央:３Dモデル表示-->
        <Viewport3D Name="View3D"  Grid.Column="1" MouseDown="View3D_MouseDown" >
            <Viewport3D.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Create Cube" Click="CreateCube_Click"/>
                    <MenuItem Header="Create Rectangle" Click="CreateRectangle_Click"/>
                    <MenuItem Header="Create Triangle" Click="CreateTriangle_Click"/>
                </ContextMenu>
            </Viewport3D.ContextMenu>

            <Viewport3D.Camera>
                <PerspectiveCamera Position="20, 20, 20"
                           LookDirection="-20, -20, -20"
                           UpDirection="0, 1, 0"
                           FieldOfView="60" />
            </Viewport3D.Camera>


        </Viewport3D>


        <!-- 右：Inspector（詳細情報） -->
        <DockPanel Grid.Column="2" Background="Gray" Margin="0,19,0,0">
            <TextBlock Text="Inspector"
               DockPanel.Dock="Top"
               Foreground="White"
               FontSize="16"
               Margin="5"
               Height="20" VerticalAlignment="Top" />

            <StackPanel Margin="10" Width="328" Height="762" VerticalAlignment="Top">
                <!-- Name -->
                <TextBlock Text="Name" Foreground="White" Margin="0,5,0,0"/>
                <TextBox x:Name="InspectorName" KeyDown="InspectorName_KeyDown"/>

                <!-- Position -->
                <TextBlock Text="Position" Foreground="White" Margin="0,10,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="X:" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="PosX" Width="50" Margin="5,0" TextChanged="Pos_TextChanged"/>
                    <TextBlock Text="Y:" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="PosY" Width="50" Margin="5,0" TextChanged="Pos_TextChanged"/>
                    <TextBlock Text="Z:" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="PosZ" Width="50" Margin="5,0" TextChanged="Pos_TextChanged"/>
                </StackPanel>

                <!-- Scale -->
                <TextBlock Text="Scale" Foreground="White" Margin="0,10,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="X:" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="ScaleX" Width="50" Margin="5,0"/>
                    <TextBlock Text="Y:" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="ScaleY" Width="50" Margin="5,0"/>
                    <TextBlock Text="Z:" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="ScaleZ" Width="50" Margin="5,0"/>
                </StackPanel>

                <!-- Rotation -->
                <TextBlock Text="Rotation" Foreground="White" Margin="0,10,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="X:" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="RotX" Width="50" Margin="5,0"/>
                    <TextBlock Text="Y:" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="RotY" Width="50" Margin="5,0"/>
                    <TextBlock Text="Z:" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="RotZ" Width="50" Margin="5,0"/>
                </StackPanel>

            </StackPanel>
        </DockPanel>

        <ComboBox x:Name="GridSize"
            SelectionChanged="GridSizeBox_SelectionChanged" Grid.Column="2" Margin="0,583,0,176" HorizontalAlignment="Center" Width="250" Height="25">
            <ComboBoxItem Content="1" />
            <ComboBoxItem Content="0.5" />
            <ComboBoxItem Content="0.25" />
            <ComboBoxItem Content="0.125" />
            <ComboBoxItem Content="0.0625" />
        </ComboBox>
        <Menu Margin="0,0,0,778" Grid.ColumnSpan="3" VerticalAlignment="Top" >
            <MenuItem Header="Folder">
                <MenuItem Header="Import" Click="Import_Click"/>
                <MenuItem Header="Export" Click="Export_Click"/>
                <MenuItem Header="Save" Click="Save_Click"/>
            </MenuItem>
            <MenuItem Header="Window"/>
            <MenuItem Header="Help"/>
        </Menu>

    </Grid>

</Window>
    