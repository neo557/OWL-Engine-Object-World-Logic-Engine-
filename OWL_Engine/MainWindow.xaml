<Window x:Class="OWL_Engine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Grid Engine'OWL Engine'"
        Width="900"
        Height="800"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="250" />
        </Grid.ColumnDefinitions>
        
        <!--左:オブジェクト階層表示-->
        <DockPanel Grid.Column="0" Background="#2222">
            <TextBlock Text="Objects" Foreground="White" FontSize="16" Margin="5" />
            <TreeView Name="ObjectTree"/>
            <ListBox x:Name="HierarchyList"
         SelectionChanged="HierarchyList_SelectionChanged"/>
        </DockPanel>

        <!--中央:３Dモデル表示-->
        <Viewport3D Name="View3D"  Grid.Column="1" MouseMove="UpdateLoop" MouseDown="View3D_MouseDown">
            <Viewport3D.Camera>
                <PerspectiveCamera Position="20, 20, 20" LookDirection="-20, -20, -20" UpDirection="0, 1, 0" FieldOfView="60" />
            </Viewport3D.Camera>
        </Viewport3D>

        <!--右:オブジェクト情報-->
        <StackPanel Grid.Column="2" Background="#222">
            <TextBlock Text="Propaties" Foreground="White" FontSize="16" Margin="5"/>
            <TextBlock Text="Position"/>
            <TextBlock Text="PosText"/>
            <TextBlock Text="Object ID"/>
            <TextBlock Text="IDText"/>
        </StackPanel>


    </Grid>

</Window>